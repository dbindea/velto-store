{
  "name": "functions",
  "description": "Cloud Functions for Velto - Redsys payments, contract PDF generation, signing links, and Resend email",
  "scripts": {
    "lint": "echo \"Skipping lint\"",
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.1.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "private": true
}
